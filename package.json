{
  "name": "plex-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Plex Media Server with Trakt, Sonarr, and Radarr integration — enables AI assistants to manage your media library",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "plex-mcp-server": "build/index.js",
    "plex-trakt-server": "build/plex-trakt-server.js",
    "plex-arr-server": "build/plex-arr-server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/niavasha/plex-mcp-server.git"
  },
  "homepage": "https://github.com/niavasha/plex-mcp-server",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "start:trakt": "node build/plex-trakt-server.js",
    "dev": "tsx src/index.ts",
    "dev:trakt": "tsx src/plex-trakt-server.ts",
    "start:arr": "node build/plex-arr-server.js",
    "dev:arr": "tsx src/plex-arr-server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "mcp",
    "plex",
    "plex-media-server",
    "ai",
    "claude",
    "model-context-protocol",
    "sonarr",
    "radarr",
    "trakt",
    "media-server",
    "home-automation"
  ],
  "author": "niavasha",
  "license": "MIT"
}
